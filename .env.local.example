# ─────────────────────────────────────────────────────────────────
# Google Search Console — MCP Server credentials
# ─────────────────────────────────────────────────────────────────
# Copie ce fichier en .env.local et remplis les valeurs.
# Ne commite JAMAIS .env.local (déjà dans .gitignore).
#
# Comment obtenir ces credentials (une seule fois) :
#
#   1. Google Cloud Console → https://console.cloud.google.com
#   2. Crée un projet (ex: "Bikawo SEO")
#   3. APIs & Services → Activer "Google Search Console API"
#   4. Credentials → "OAuth 2.0 Client ID" → Type : Application de bureau
#   5. Télécharge le JSON → récupère client_id et client_secret
#   6. Génère le refresh_token via OAuth Playground :
#        https://developers.google.com/oauthplayground
#        → Scope : https://www.googleapis.com/auth/webmasters.readonly
#        → "Exchange authorization code for tokens"
#        → Copie le refresh_token
# ─────────────────────────────────────────────────────────────────

GSC_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GSC_CLIENT_SECRET=your_client_secret_here
GSC_REFRESH_TOKEN=your_refresh_token_here

# URL de la propriété GSC — choisir le bon format selon ta config GSC :
# "sc-domain:bikawo.fr"        → Domain property (recommandé)
# "https://bikawo.fr/"         → URL prefix property
GSC_SITE_URL=sc-domain:bikawo.fr
