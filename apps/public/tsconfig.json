{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@bikawo/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@bikawo/shared/*": [
        "../../packages/shared/src/*"
      ],
      "react": ["./node_modules/@types/react"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime"],
      "@supabase/supabase-js": ["./node_modules/@supabase/supabase-js"],
      "react-router-dom": ["./node_modules/react-router-dom"],
      "sonner": ["./node_modules/sonner"],
      "class-variance-authority": ["./node_modules/class-variance-authority"],
      "clsx": ["./node_modules/clsx"],
      "tailwind-merge": ["./node_modules/tailwind-merge"],
      "lucide-react": ["./node_modules/lucide-react"],
      "cmdk": ["./node_modules/cmdk"],
      "vaul": ["./node_modules/vaul"],
      "embla-carousel-react": ["./node_modules/embla-carousel-react"],
      "recharts": ["./node_modules/recharts"],
      "date-fns": ["./node_modules/date-fns"],
      "react-day-picker": ["./node_modules/react-day-picker"],
      "react-resizable-panels": ["./node_modules/react-resizable-panels"],
      "input-otp": ["./node_modules/input-otp"],
      "@radix-ui/react-accordion": ["./node_modules/@radix-ui/react-accordion"],
      "@radix-ui/react-alert-dialog": ["./node_modules/@radix-ui/react-alert-dialog"],
      "@radix-ui/react-aspect-ratio": ["./node_modules/@radix-ui/react-aspect-ratio"],
      "@radix-ui/react-avatar": ["./node_modules/@radix-ui/react-avatar"],
      "@radix-ui/react-checkbox": ["./node_modules/@radix-ui/react-checkbox"],
      "@radix-ui/react-collapsible": ["./node_modules/@radix-ui/react-collapsible"],
      "@radix-ui/react-context-menu": ["./node_modules/@radix-ui/react-context-menu"],
      "@radix-ui/react-dialog": ["./node_modules/@radix-ui/react-dialog"],
      "@radix-ui/react-dropdown-menu": ["./node_modules/@radix-ui/react-dropdown-menu"],
      "@radix-ui/react-hover-card": ["./node_modules/@radix-ui/react-hover-card"],
      "@radix-ui/react-label": ["./node_modules/@radix-ui/react-label"],
      "@radix-ui/react-menubar": ["./node_modules/@radix-ui/react-menubar"],
      "@radix-ui/react-navigation-menu": ["./node_modules/@radix-ui/react-navigation-menu"],
      "@radix-ui/react-popover": ["./node_modules/@radix-ui/react-popover"],
      "@radix-ui/react-progress": ["./node_modules/@radix-ui/react-progress"],
      "@radix-ui/react-radio-group": ["./node_modules/@radix-ui/react-radio-group"],
      "@radix-ui/react-scroll-area": ["./node_modules/@radix-ui/react-scroll-area"],
      "@radix-ui/react-select": ["./node_modules/@radix-ui/react-select"],
      "@radix-ui/react-separator": ["./node_modules/@radix-ui/react-separator"],
      "@radix-ui/react-slider": ["./node_modules/@radix-ui/react-slider"],
      "@radix-ui/react-slot": ["./node_modules/@radix-ui/react-slot"],
      "@radix-ui/react-switch": ["./node_modules/@radix-ui/react-switch"],
      "@radix-ui/react-tabs": ["./node_modules/@radix-ui/react-tabs"],
      "@radix-ui/react-toast": ["./node_modules/@radix-ui/react-toast"],
      "@radix-ui/react-toggle": ["./node_modules/@radix-ui/react-toggle"],
      "@radix-ui/react-toggle-group": ["./node_modules/@radix-ui/react-toggle-group"],
      "@radix-ui/react-tooltip": ["./node_modules/@radix-ui/react-tooltip"],
      "react-hook-form": ["./node_modules/react-hook-form"],
      "next-themes": ["./node_modules/next-themes"],
      "zod": ["./node_modules/zod"],
      "@hookform/resolvers": ["./node_modules/@hookform/resolvers"],
      "@hookform/resolvers/*": ["./node_modules/@hookform/resolvers/*"]
    },
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2020",
    "useDefineForClassFields": true
  },
  "include": [
    "src"
  ]
}
